Algoritmo "semnome"



Var
 salario:real
 divisao:real
 salario_minimo:real
 nome










Inicio
      salario_minimo <- 1621.00
      
      
      
      escreval(" valor do  salario")
      leia(salario)

      divisao <- salario / salario_minimo
      
      escreval("quantidade de salario : ", divisao:3:7)












Fimalgoritmo